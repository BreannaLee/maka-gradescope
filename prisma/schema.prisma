generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          String   @default("creator") // creator, editorial_t1, editorial_t2
  name          String
  bio           String?
  avatarUrl     String?
  status        String   @default("active") // pending, approved, active, deactivated
  creatorGrade  String?
  approvedCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastActiveAt  DateTime @default(now())

  projects      Project[]
  evaluations   Evaluation[]
  comments      Comment[]
  notifications Notification[]
  resolvedFlags SafetyFlag[]   @relation("ResolvedBy")
  timestampedFeedback TimestampedFeedback[]
}

model Project {
  id                String   @id @default(uuid())
  creatorId         String
  title             String
  seriesName        String
  season            Int
  episode           Int
  ageBracket        String
  estimatedDuration String?
  thumbnailUrl      String?
  currentStage      String   @default("idea")
  status            String   @default("new")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  creator      User          @relation(fields: [creatorId], references: [id])
  stages       Stage[]
  chatMessages ChatMessage[]
}

model Stage {
  id               String    @id @default(uuid())
  projectId        String
  stageType        String
  status           String    @default("not_started")
  version          Int       @default(1)
  uploadedFileUrl  String?
  uploadedFileName String?
  chatbotSummary   String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]
  comments    Comment[]
  safetyFlags SafetyFlag[]
}

model Evaluation {
  id             String   @id @default(uuid())
  stageId        String
  evaluationType String
  evaluatorId    String?
  overallScore   Float
  overallGrade   String
  summary        String
  suggestedSteps String
  isOverride     Boolean  @default(false)
  createdAt      DateTime @default(now())
  version        Int      @default(1)

  stage        Stage         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  evaluator    User?         @relation(fields: [evaluatorId], references: [id])
  domainScores DomainScore[]
  timestampedFeedback TimestampedFeedback[]
}

model DomainScore {
  id           String @id @default(uuid())
  evaluationId String
  domain       String
  score        Float
  grade        String
  feedback     String
  benchmark    Float

  evaluation     Evaluation          @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  subIndicators  SubIndicatorScore[]
}

model SubIndicatorScore {
  id            String  @id @default(uuid())
  domainScoreId String
  indicatorName String
  score         Int
  maxScore      Int     @default(5)
  feedback      String?

  domainScore DomainScore @relation(fields: [domainScoreId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(uuid())
  projectId String
  stageType String
  role      String
  content   String
  rating    String?
  createdAt DateTime @default(now())
  metadata  String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimestampedFeedback {
  id              String  @id @default(uuid())
  evaluationId    String
  timecode        String
  timecodeSeconds Int
  note            String
  domain          String
  feedbackType    String
  authorId        String?

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  author     User?      @relation(fields: [authorId], references: [id])
}

model Comment {
  id          String   @id @default(uuid())
  stageId     String
  authorId    String
  commentType String
  content     String
  anchor      String
  createdAt   DateTime @default(now())
  resolved    Boolean  @default(false)

  stage  Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

model SafetyFlag {
  id            String   @id @default(uuid())
  stageId       String
  flagType      String
  severity      String
  description   String
  autoGenerated Boolean  @default(true)
  resolved      Boolean  @default(false)
  resolvedById  String?
  createdAt     DateTime @default(now())

  stage      Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ResolvedBy", fields: [resolvedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  emailed   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Article {
  id          String   @id @default(uuid())
  title       String
  content     String
  contentType String
  domains     String
  thumbnailUrl String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
